@page "/Ventas/Facturacion/Index"

<PageTitle>Facturación</PageTitle>

<EditForm Model="ListaFacturas" class="border shadow-lg p-3 rounded">
    <div class="container mt-4">
        <div class="row justify-content-center">
            <div class="col-md-auto">
                <div class="card border-0 rounded-3">
                    <div class="card-body">
                        <div class="row align-items-center">
                            <div class="col-md-3 text-center text-md-end mb-3 mb-md-0">
                                <label class="d-inline-block fs-4 fw-bold text-black">Código del producto </label>
                            </div>

                            <div class="col-md-6 d-flex align-items-center mb-3 mb-md-0">
                                <div class="input-group input-group-lg flex-grow-1 me-3">
                                    <input @bind="valorFiltro" class="form-control" placeholder="Buscar..." />
                                </div>

                                <div class="d-flex align-items-center">
                                    <label for="Cantidad" class="form-label fw-bold me-2 mb-0">Cantidad:</label>
                                    <input type="text" id="Cantidad" class="form-control me-3" style="width: 100px;" @bind="cantidad" />

                                    <button type="button" class="btn btn-outline-secondary d-flex align-items-center gap-2" @onclick="Restablecer">
                                        <i class="bi bi-arrow-counterclockwise"></i>
                                    </button>
                                </div>
                            </div>

                            <div class="col-md-3 d-flex justify-content-end">
                                <button @onclick="Añadir" class="btn btn-success" type="button" style="background-color: #004b55; border-color: #004b55;">
                                    <span class="bi bi-plus"></span> Registro
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <table class="table table-striped table-hover table-bordered text-center align-middle">
        <thead class="bg-dark text-black">
            <tr>
                <th>#</th>
                <th>Código</th>
                <th>Descripción</th>
                <th>Cantidad</th>
                <th>Precio</th>
                <th>Editar</th>
                <th>Eliminar</th>
            </tr>
        </thead>
        <tbody class="text-white">
            @foreach (var factura in ListaFacturas)
            {
                <tr>
                    <td class="text-black">@factura.OrdenVentaId</td>
                    <td class="text-black">@factura.OrdenVenta?.Codigo</td>
                    <td class="text-black">@factura.Productos?.Nombre</td>
                    <td class="text-black">@factura.Cantidad</td>
                    <td class="text-black">@factura.Productos?.Precio</td>
                    <td>
                        <a href="/Ventas/Facturacion/Edit/@factura.OrdenVenta?.OrdenVentaId" class="btn btn-info btn-sm">
                            <i class="bi bi-eye"></i>
                        </a>
                        <a href="/Ventas/Facturacion/Delete/@factura.OrdenVenta?.OrdenVentaId" class="btn btn-danger btn-sm">
                            <i class="bi bi-trash"></i>
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <div class="d-flex justify-content-between align-items-center mt-4">
        <a href="/Ventas/Cobro" class="btn btn-danger d-flex align-items-center px-3 py-2">
            <i class="bi bi-cash me-2"></i> Cobrar
        </a>
    </div>

    <div class="card-footer text-start">
        <p>Total de Facturas: @ListaFacturas.Count</p>
    </div>
</EditForm>

@code {
    [Parameter]
    public int OrdenVentaId { get; set; }
    public List<OrdenVentaDetalle> ListaFacturas { get; set; } = new List<OrdenVentaDetalle>();
    private string valorFiltro = "";
    private int cantidad = 1;

    public async Task Buscar()
    {
        // Implementación de búsqueda si es necesaria
    }

    private async Task Restablecer()
    {
        valorFiltro = "";
        cantidad = 1;
    }

    private async Task Añadir()
    {
        if (!string.IsNullOrWhiteSpace(valorFiltro))
        {
            var producto = await ObtenerProductoPorCodigo(valorFiltro);
            if (producto != null)
            {
                ListaFacturas.Add(new OrdenVentaDetalle
                    {
                        OrdenVentaId = OrdenVentaId,
                        ProductoId = producto.ProductoId,
                        Productos = producto,
                        Cantidad = cantidad,
                        Subtotal = (double)(producto.Precio * cantidad)
                    });
            }
        }
    }

    private async Task<Productos?> ObtenerProductoPorCodigo(string codigo)
    {
        // Simulación de búsqueda del producto (debería conectarse a un servicio o base de datos)
        return new Productos { ProductoId = 1, Codigo = codigo, Nombre = "Ejemplo", Precio = 100 };
    }
}
