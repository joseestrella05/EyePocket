@page "/Ventas/Pago"
@using Microsoft.AspNetCore.Components
@inject NavigationManager Navigation

<PageTitle>Pago a Credito</PageTitle>

<div class="d-flex vh-75">
    <!-- Panel Izquierdo -->
    <div class="text-white p-4 d-flex flex-column justify-content-center" style="width: 30%; background-color: #004b55;">
        <h5 class="fw-bold">Contacto</h5>
        <select class="form-control" @bind="ContactoSeleccionado">
            <option value="buscar">Buscar...</option>
            <option value="contacto1">Contacto 1</option>
            <option value="contacto2">Contacto 2</option>
            <option value="contacto3">Contacto 3</option>
        </select>
        <button class="btn btn-light w-100 mt-2">Nuevo Contacto</button>
    </div>

    <!-- Panel Derecho -->
    <div class="bg-light p-4 d-flex flex-column align-items-center justify-content-center flex-grow-1">
        <h3>Pago a Credito</h3>

        <div class="form-group w-50">
            <label for="identificacion">Identificación</label>
            <input type="text" id="identificacion" class="form-control" @bind="Identificacion">
        </div>

        <div class="form-group w-50">
            <label for="telefono">Teléfono</label>
            <input type="text" id="telefono" class="form-control" @bind="Telefono">
        </div>

        <div class="form-group w-50">
            <label for="fecha">Fecha</label>
            <input type="text" id="fecha" class="form-control" @bind="Fecha">
        </div>

        <div class="form-group w-50">
            <label for="plazo">Plazo de pago</label>
            <input type="text" id="plazo" class="form-control" @bind="Plazo">
        </div>

        <div class="form-group w-50">
            <label for="vencimiento">Vencimiento</label>
            <input type="text" id="vencimiento" class="form-control" @bind="Vencimiento">
        </div>
    </div>
</div>

@code {
    private string ContactoSeleccionado { get; set; } = "buscar";
    private string Identificacion { get; set; } = "";
    private string Telefono { get; set; } = "";
    private string Fecha { get; set; } = "04/10/2021";
    private string Plazo { get; set; } = "45 días";
    private string Vencimiento { get; set; } = "18/11/2021";
}
